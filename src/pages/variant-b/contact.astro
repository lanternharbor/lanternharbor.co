---
import Layout from '../../layouts/Layout.astro';
import ContactForm from '../../components/ContactForm.astro';
import NextSteps from '../../components/NextSteps.astro';
import PreviewNotice from '../../components/PreviewNotice.astro';
import { variantBSections } from '../../data/siteVariants';

const page = variantBSections.contact;
---

<Layout
  title={page.title}
  description={page.description}
  pageKey="contact"
  navBasePath="/variant-b"
  noindex={true}
>
  <PreviewNotice
    title="Variant B Contact"
    body="A more direct contact page with clearer expectations about the first conversation and next step."
    primaryHref="/contact"
    primaryLabel="See Variant A contact"
  />

  <article class="contact-page section">
    <div class="container container--content">
      <header class="contact-page__intro">
        <h1 class="contact-page__title">{page.title}</h1>
        <p class="contact-page__lede">{page.lede}</p>
        <p class="contact-page__lede contact-page__lede--dim">
          {page.sublede}
        </p>
      </header>

      <div class="contact-page__grid">
        <section class="contact-page__form-col" aria-labelledby="send-note">
          <h2 id="send-note" class="contact-page__section-heading">
            Send a note
          </h2>
          <ContactForm
            submitLabel={page.submitLabel}
            reassurance={page.reassurance}
          />
        </section>

        <div class="contact-page__aside-col">
          <NextSteps
            heading={page.nextSteps.heading}
            lede={page.nextSteps.lede}
            items={page.nextSteps.items}
          />

          <aside class="contact-page__direct" aria-labelledby="direct-contact">
            <h2 id="direct-contact" class="contact-page__section-heading">
              Or reach me directly
            </h2>

            <dl class="direct-contact">
              <div class="direct-contact__row">
                <dt class="direct-contact__label">Call or text</dt>
                <dd class="direct-contact__value">
                  <a href="tel:+17817242543" class="direct-contact__link">
                    (781) 724-2543
                  </a>
                  <a href="sms:+17817242543" class="direct-contact__secondary">
                    Text instead
                  </a>
                </dd>
              </div>

              <div class="direct-contact__row">
                <dt class="direct-contact__label">Email</dt>
                <dd class="direct-contact__value">
                  <a
                    href="mailto:william@lanternharbor.co"
                    class="direct-contact__link"
                  >
                    william<wbr />@lanternharbor.co
                  </a>
                </dd>
              </div>

              <div class="direct-contact__row">
                <dt class="direct-contact__label">Based in</dt>
                <dd class="direct-contact__value">Hingham, Massachusetts</dd>
              </div>
            </dl>

            <p class="direct-contact__note">
              If you're on the South Shore, I'll happily drive to you and talk
              in person.
            </p>
          </aside>
        </div>
      </div>
    </div>
  </article>
</Layout>

<style>
  .contact-page {
    padding-top: var(--space-8);
    padding-bottom: var(--space-10);
  }
  @media (min-width: 48rem) {
    .contact-page {
      padding-top: var(--space-9);
    }
  }

  .contact-page__intro {
    max-width: 44rem;
    margin-bottom: var(--space-8);
  }

  .contact-page__title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: var(--step-5);
    line-height: 1.1;
    letter-spacing: -0.015em;
    color: var(--color-harbor);
    margin: 0 0 var(--space-4);
  }

  .contact-page__lede {
    font-size: var(--step-1);
    line-height: 1.6;
    color: var(--color-slate);
    margin: 0 0 var(--space-3);
    max-width: 38em;
  }

  .contact-page__lede--dim {
    color: var(--color-driftwood);
    font-size: var(--step-0);
  }

  .contact-page__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    align-items: start;
  }

  @media (min-width: 52rem) {
    .contact-page__grid {
      grid-template-columns: minmax(0, 1.45fr) minmax(0, 1fr);
      gap: var(--space-8);
    }
  }

  .contact-page__aside-col {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .contact-page__section-heading {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: var(--step-3);
    color: var(--color-harbor);
    margin: 0 0 var(--space-5);
    line-height: 1.2;
  }

  .contact-page__direct {
    padding: var(--space-6);
    background-color: rgba(229, 192, 103, 0.08);
    border: 1px solid rgba(229, 192, 103, 0.25);
    border-radius: var(--radius);
  }

  .direct-contact {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    margin: 0;
  }

  .direct-contact__row {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .direct-contact__label {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: var(--step--1);
    color: var(--color-harbor);
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .direct-contact__value {
    margin: 0;
    font-size: var(--step-0);
    line-height: 1.5;
    color: var(--color-slate);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .direct-contact__link {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: var(--step-1);
    color: var(--color-harbor);
    text-decoration: none;
    line-height: 1.3;
    transition: color var(--transition);
  }

  a.direct-contact__link[href^="mailto:"] {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: var(--step-0);
    overflow-wrap: break-word;
  }

  .direct-contact__link:hover,
  .direct-contact__link:focus-visible {
    color: var(--color-brass);
  }

  .direct-contact__secondary {
    font-size: var(--step--1);
    color: var(--color-driftwood);
    text-decoration-color: rgba(184, 134, 75, 0.5);
    text-underline-offset: 3px;
  }

  .direct-contact__secondary:hover,
  .direct-contact__secondary:focus-visible {
    color: var(--color-harbor);
  }

  .direct-contact__note {
    font-size: var(--step--1);
    line-height: 1.6;
    color: var(--color-driftwood);
    font-style: italic;
    margin: var(--space-5) 0 0;
    padding-top: var(--space-4);
    border-top: 1px solid rgba(15, 42, 63, 0.08);
  }
</style>
