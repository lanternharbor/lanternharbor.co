---
import { getEntry, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import CardSection from '../../components/CardSection.astro';
import PreviewNotice from '../../components/PreviewNotice.astro';
import { variantBSections } from '../../data/siteVariants';

const entry = await getEntry('pages', 'about');
if (!entry) throw new Error('Missing content/pages/about.md');

const { Content } = await render(entry);
const { workingPrinciples } = entry.data;
const page = variantBSections.about;
---

<Layout
  title={page.title}
  description={page.description}
  pageKey="about"
  navBasePath="/variant-b"
  noindex={true}
>
  <PreviewNotice
    title="Variant B About"
    body="A more commercially direct About page, with credibility front-loaded before the story behind Lantern Harbor."
    primaryHref="/about"
    primaryLabel="See Variant A about"
  />

  <article class="about-page">
    <section class="about-page__intro section">
      <div class="container container--reading">
        <header class="about-page__header">
          <h1 class="about-page__title">{page.title}</h1>
          <div class="about-page__lede">
            {page.intro.map((paragraph) => (
              <p>{paragraph}</p>
            ))}
          </div>
        </header>
      </div>
    </section>

    <CardSection
      heading={page.credibility.heading}
      lede={page.credibility.lede}
      items={page.credibility.items}
      columns={2}
      sectionClass="section section--tight"
    />

    <section class="about-page__narrative section section--tight">
      <div class="container container--reading prose">
        <Content />
      </div>
    </section>

    {workingPrinciples && (
      <CardSection
        heading={workingPrinciples.heading}
        lede={workingPrinciples.lede}
        items={workingPrinciples.items}
        columns={3}
        sectionClass="section section--tight"
      />
    )}
  </article>
</Layout>

<style>
  .about-page__intro {
    padding-top: var(--space-8);
    padding-bottom: var(--space-4);
  }

  @media (min-width: 48rem) {
    .about-page__intro {
      padding-top: var(--space-9);
    }
  }

  .about-page__header {
    max-width: 44rem;
  }

  .about-page__title {
    margin: 0 0 var(--space-4);
    font-size: var(--step-5);
    line-height: 1.1;
    letter-spacing: -0.015em;
  }

  .about-page__lede {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .about-page__lede p {
    margin: 0;
    font-size: var(--step-1);
    line-height: 1.7;
    color: var(--color-slate);
  }

  .about-page__narrative {
    padding-top: 0;
    padding-bottom: var(--space-6);
  }

  .about-page__narrative :global(.prose > h2:first-child) {
    margin-top: 0;
  }
</style>
