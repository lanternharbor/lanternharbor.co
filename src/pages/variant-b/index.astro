---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import ProofStrip from '../../components/ProofStrip.astro';
import CardSection from '../../components/CardSection.astro';
import ProcessSection from '../../components/ProcessSection.astro';
import RecentWorkSection from '../../components/RecentWorkSection.astro';
import CalloutPanel from '../../components/CalloutPanel.astro';
import PreviewNotice from '../../components/PreviewNotice.astro';
import { variantBSections } from '../../data/siteVariants';

const home = variantBSections.home;
---

<Layout
  title={home.title}
  description={home.description}
  pageKey="home"
  navBasePath="/variant-b"
  noindex={true}
>
  <PreviewNotice
    title="Variant B"
    body="A sharper commercial version of the Lantern Harbor homepage and core interior pages. Same brand, more direct packaging."
    primaryHref="/"
    primaryLabel="See Variant A on the main site"
  />

  <Hero
    eyebrow={home.hero.eyebrow}
    headline={home.hero.headline}
    tagline={home.hero.tagline}
    ctaPrimary={home.hero.ctaPrimary}
    ctaSecondary={home.hero.ctaSecondary}
  />

  <ProofStrip items={home.proof} />

  <CardSection
    heading={home.scenarios.heading}
    lede={home.scenarios.lede}
    items={home.scenarios.items}
    columns={2}
    sectionClass="section section--tight"
  />

  <section class="variant-home__who section section--tight">
    <div class="container container--reading">
      <h2 class="variant-home__who-heading">{home.who.heading}</h2>
      <p class="variant-home__who-body">{home.who.body}</p>
    </div>
  </section>

  <CardSection
    heading={home.offersPreview.heading}
    lede={home.offersPreview.lede}
    items={home.offersPreview.items}
    columns={2}
    sectionClass="section section--tight"
  />

  <ProcessSection
    heading={home.process.heading}
    lede={home.process.lede}
    items={home.process.items}
  />

  <RecentWorkSection
    heading={home.recentWork.heading}
    lede={home.recentWork.lede}
    note={home.recentWork.note}
    viewAllLabel={home.recentWork.viewAllLabel}
    viewAllHref={home.recentWork.viewAllHref}
  />

  <CalloutPanel
    heading={home.closing.heading}
    body={home.closing.body}
    primaryLabel={home.closing.primaryLabel}
    primaryHref={home.closing.primaryHref}
    secondaryLabel={home.closing.secondaryLabel}
    secondaryHref={home.closing.secondaryHref}
  />
</Layout>

<style>
  .variant-home__who {
    padding-top: 0;
  }

  .variant-home__who-heading {
    margin: 0 0 var(--space-3);
    font-size: var(--step-3);
  }

  .variant-home__who-body {
    margin: 0;
    font-size: var(--step-1);
    line-height: 1.7;
    color: var(--color-slate);
  }
</style>
