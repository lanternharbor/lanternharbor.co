---
import { getEntry, render } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import CardSection from '../components/CardSection.astro';
import { variantASections } from '../data/siteVariants';

const entry = await getEntry('pages', 'about');
if (!entry) throw new Error('Missing content/pages/about.md');

const { Content } = await render(entry);
const { title, description, workingPrinciples } = entry.data;
---

<Layout title={title} description={description} pageKey="about">
  <article class="about-page">
    <section class="about-page__intro section">
      <div class="container container--content">
        <header class="about-page__header">
          <h1 class="about-page__title">About</h1>
          <div class="about-page__lede">
            {variantASections.about.intro.map((paragraph) => (
              <p>{paragraph}</p>
            ))}
          </div>
          <figure class="about-page__portrait">
            <img
              src="/lantern_harbor_photo_800x800.jpg"
              alt="William Keough"
              width="800"
              height="800"
              loading="eager"
              decoding="async"
            />
          </figure>
        </header>
      </div>
    </section>

    <CardSection
      heading={variantASections.about.credibility.heading}
      lede={variantASections.about.credibility.lede}
      items={variantASections.about.credibility.items}
      columns={2}
      sectionClass="section section--tight"
    />

    <section class="about-page__narrative section section--tight">
      <div class="container container--content">
        <div class="prose">
          <Content />
        </div>
      </div>
    </section>

    {workingPrinciples && (
      <CardSection
        heading={workingPrinciples.heading}
        lede={workingPrinciples.lede}
        items={workingPrinciples.items}
        columns={2}
        sectionClass="section section--tight"
      />
    )}
  </article>
</Layout>

<style>
  .about-page__intro {
    padding-top: var(--space-8);
    padding-bottom: var(--space-4);
  }

  @media (min-width: 48rem) {
    .about-page__intro {
      padding-top: var(--space-9);
    }
  }

  .about-page__header {
    max-width: var(--measure-reading);
  }

  @media (min-width: 48rem) {
    .about-page__header {
      display: grid;
      grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
      grid-template-areas:
        "title portrait"
        "lede  portrait";
      gap: var(--space-6);
      align-items: start;
    }

    .about-page__title {
      grid-area: title;
    }

    .about-page__lede {
      grid-area: lede;
    }

    .about-page__portrait {
      grid-area: portrait;
    }
  }

  .about-page__title {
    margin: 0 0 var(--space-4);
    font-size: var(--step-5);
    line-height: 1.1;
    letter-spacing: -0.015em;
  }

  .about-page__lede {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .about-page__lede p {
    margin: 0;
    font-size: var(--step-1);
    line-height: 1.7;
    color: var(--color-slate);
  }

  .about-page__portrait {
    margin: var(--space-5) 0 0;
    max-width: 14rem;
  }

  @media (min-width: 48rem) {
    .about-page__portrait {
      margin-top: 0;
      max-width: 18rem;
    }
  }

  .about-page__portrait img {
    width: 100%;
    height: auto;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: var(--radius);
    border: 1px solid rgba(15, 42, 63, 0.08);
    display: block;
  }

  .about-page__narrative {
    padding-top: 0;
    padding-bottom: var(--space-6);
  }

  .about-page__narrative :global(.prose) {
    margin-inline: 0;
  }

  .about-page__narrative :global(.prose > h2:first-child) {
    margin-top: 0;
  }
</style>
