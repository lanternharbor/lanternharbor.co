---
import Layout from '../layouts/Layout.astro';
import WorkShowcase from '../components/WorkShowcase.astro';

const pageTitle = 'Selected Work — Websites & Small Software Builds';
const pageDescription =
  "Recent websites, iOS apps, and small software builds from Lantern Harbor — selected client engagements and the hand-built lanternharbor.co site itself.";
---

<Layout title={pageTitle} description={pageDescription} pageKey="work">
  <WorkShowcase
    title="Work"
    lede="A few recent websites, tools, and product builds. Some are client-facing, some are self-initiated, and all are representative of how I like to work: clear, practical, and carefully finished."
    note="Not every engagement is public. Advisory work and internal systems often stay private."
    ctaHref="/contact"
    ctaText="Get in touch"
  />
</Layout>
