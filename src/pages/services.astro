---
import { getEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import OfferGrid from '../components/OfferGrid.astro';
import CalloutPanel from '../components/CalloutPanel.astro';
import { variantASections } from '../data/siteVariants';

const entry = await getEntry('pages', 'services');
if (!entry) throw new Error('Missing content/pages/services.md');

const { title, description } = entry.data;
---

<Layout title={title} description={description} pageKey="services">
  <OfferGrid
    heading="How I help"
    lede={variantASections.services.lede}
    note={variantASections.services.note}
    offers={variantASections.services.offers}
  />

  <section class="who-i-work-with section section--tight">
    <div class="container container--content">
      <h2 class="who-i-work-with__heading">Who I work with</h2>
      <p class="who-i-work-with__body">
        Small and mid-sized businesses on the South Shore — trades and
        construction, retail, restaurants and hospitality, charter and marine
        services, professional services (accountants, attorneys, real estate,
        financial planners), local manufacturers, and non-healthcare
        nonprofits. If your business doesn't quite fit that list, ask anyway —
        I'd rather say so than guess.
      </p>
    </div>
  </section>

  <CalloutPanel
    heading={variantASections.services.closing.heading}
    body={variantASections.services.closing.body}
    primaryLabel={variantASections.services.closing.primaryLabel}
    primaryHref={variantASections.services.closing.primaryHref}
  />
</Layout>

<style>
  .who-i-work-with {
    padding-top: 0;
  }

  .who-i-work-with__heading {
    margin: 0 0 var(--space-3);
    font-size: var(--step-3);
    line-height: 1.2;
    letter-spacing: -0.01em;
    color: var(--color-harbor);
  }

  .who-i-work-with__body {
    margin: 0;
    font-size: var(--step-1);
    line-height: 1.65;
    color: var(--color-slate);
    max-width: var(--measure-reading);
  }
</style>
