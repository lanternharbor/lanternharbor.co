---
import { getEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import ProofStrip from '../components/ProofStrip.astro';
import CardSection from '../components/CardSection.astro';
import ProcessSection from '../components/ProcessSection.astro';
import RecentWorkSection from '../components/RecentWorkSection.astro';
import CalloutPanel from '../components/CalloutPanel.astro';
import { variantASections } from '../data/siteVariants';

const entry = await getEntry('pages', 'home');
if (!entry) throw new Error('Missing content/pages/home.md');
if (!entry.data.hero) throw new Error('home.md is missing a `hero` frontmatter block');

const { title, description, hero } = entry.data;
---

<Layout title={title} description={description} pageKey="home">
  <Hero
    eyebrow={hero.eyebrow}
    headline={hero.headline}
    tagline={hero.tagline}
    ctaPrimary={hero.ctaPrimary}
    ctaSecondary={hero.ctaSecondary}
  />

  <ProofStrip items={variantASections.home.proof} />

  <CardSection
    heading={variantASections.home.scenarios.heading}
    lede={variantASections.home.scenarios.lede}
    items={variantASections.home.scenarios.items}
    columns={2}
    sectionClass="section section--tight"
  />

  <CardSection
    heading={variantASections.home.offersPreview.heading}
    lede={variantASections.home.offersPreview.lede}
    items={variantASections.home.offersPreview.items}
    columns={2}
    sectionClass="section section--tight"
  />

  <ProcessSection
    heading={variantASections.home.process.heading}
    lede={variantASections.home.process.lede}
    items={variantASections.home.process.items}
  />

  <RecentWorkSection
    heading={variantASections.home.recentWork.heading}
    lede={variantASections.home.recentWork.lede}
    note={variantASections.home.recentWork.note}
    viewAllLabel={variantASections.home.recentWork.viewAllLabel}
    viewAllHref={variantASections.home.recentWork.viewAllHref}
  />

  <CalloutPanel
    heading={variantASections.home.closing.heading}
    body={variantASections.home.closing.body}
    primaryLabel={variantASections.home.closing.primaryLabel}
    primaryHref={variantASections.home.closing.primaryHref}
    secondaryLabel={variantASections.home.closing.secondaryLabel}
    secondaryHref={variantASections.home.closing.secondaryHref}
  />
</Layout>
