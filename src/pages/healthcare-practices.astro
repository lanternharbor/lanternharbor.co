---
import Layout from '../layouts/Layout.astro';
import CardSection from '../components/CardSection.astro';
import CalloutPanel from '../components/CalloutPanel.astro';
import Button from '../components/Button.astro';

const pageTitle = 'Technology Help for Healthcare Practices';
const pageDescription =
  'Lantern Harbor brings twelve years of enterprise healthcare IT to small practices, clinics, and healthcare service businesses on the South Shore of Massachusetts.';

const situations = [
  {
    title: 'You are choosing between practice management systems or EHRs.',
    body: 'The options all sound the same in a demo. You need someone who has seen what actually matters after the sales call ends: training burden, data migration, interoperability, and the hidden costs nobody mentions until month three.',
  },
  {
    title: 'You want to use AI for intake, scheduling, or documentation.',
    body: 'Some of it is real and useful. Some of it is not ready. You deserve a plain answer about which is which, from someone who has seen both in healthcare settings.',
  },
  {
    title: 'Your front desk is drowning in manual work.',
    body: 'Faxes, phone trees, paper forms, duplicate data entry. The friction points in a small practice are well-known and often fixable with modest automation that does not require replacing the whole system.',
  },
  {
    title: 'Your website does not explain the practice clearly.',
    body: 'Patients choose providers partly based on how the site feels. If the site is vague, dated, or hard to navigate, it is costing you referrals whether you notice or not.',
  },
];

const whatIDo = [
  {
    title: 'Vendor and system selection',
    body: 'Plain-language comparison of the tools actually in play: EHRs, PM systems, patient portals, telehealth platforms. Not a feature checklist. A real recommendation.',
  },
  {
    title: 'AI and automation for clinical admin',
    body: 'Where current AI tools help with intake, scheduling, documentation, and billing, and where they are not trustworthy enough yet. No hype, no pilot for its own sake.',
  },
  {
    title: 'Workflow and process improvement',
    body: 'A morning watching how the front desk, billing, and clinical handoffs actually run. Then a short, prioritized fix list. Easy wins first.',
  },
  {
    title: 'Website clarity for practices',
    body: 'If the site does not clearly explain what you treat, who you treat, and how to get in touch, it is leaving referrals on the table. A focused clarity pass changes that.',
  },
];
---

<Layout title={pageTitle} description={pageDescription} pageKey="healthcare">
  <section class="landing section">
    <div class="container container--content">
      <header class="landing__intro">
        <p class="eyebrow">Healthcare practices</p>
        <h1 class="landing__title">
          Enterprise healthcare IT experience, sized for your practice.
        </h1>
        <div class="landing__body">
          <p>
            I spent more than twelve years inside enterprise healthcare IT.
            Large hospital systems, multi-site implementations, the kind of
            projects where the technology is the easy part and the hard part is
            getting it to land with busy clinicians and staff.
          </p>
          <p>
            Now I bring that same judgment to small practices, clinics, and
            healthcare service businesses on the South Shore. The difference
            between a twelve-person dental office and a twelve-hundred-bed
            hospital is scale, not complexity. The decisions are the same; the
            pace is just faster when there are fewer people in the room.
          </p>
        </div>
        <div class="landing__ctas">
          <Button href="/contact">Let's talk</Button>
          <Button href="/services" variant="ghost" arrow={false}>
            See where I can help
          </Button>
        </div>
      </header>
    </div>
  </section>

  <section class="healthcare-note section section--tight">
    <div class="container container--reading">
      <h2 class="healthcare-note__heading">
        What I will not do
      </h2>
      <p class="healthcare-note__body">
        I do not customize clinical software inside an EHR. That is specialist
        work for firms like Nordic or Impact Advisors, and I am happy to refer
        you. I also do not take on enterprise RFPs, ongoing break-fix support,
        or work that really needs a full-time hire. If any of those is what you
        need, I will say so plainly and point you in the right direction.
      </p>
    </div>
  </section>

  <CardSection
    heading="When practices call"
    lede="A few of the conversations I end up in with healthcare owners and practice managers."
    items={situations}
    columns={2}
    sectionClass="section section--tight"
  />

  <CardSection
    heading="What I help with"
    lede="The work I do for practices usually falls into one of these areas."
    items={whatIDo}
    columns={2}
    sectionClass="section section--tight"
  />

  <CalloutPanel
    heading="The first conversation is free."
    body="You tell me what is going on, I ask a few questions, and we figure out whether there is a fit."
    primaryLabel="Let's talk"
    primaryHref="/contact"
    secondaryLabel="See where I can help"
    secondaryHref="/services"
  />
</Layout>

<style>
  .landing {
    padding-top: var(--space-8);
    padding-bottom: var(--space-6);
  }

  @media (min-width: 48rem) {
    .landing {
      padding-top: var(--space-9);
    }
  }

  .landing__intro {
    max-width: 42rem;
  }

  .landing__title {
    margin: 0 0 var(--space-4);
    font-size: var(--step-5);
    line-height: 1.1;
    letter-spacing: -0.015em;
  }

  .landing__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }

  .landing__body p {
    margin: 0;
    font-size: var(--step-1);
    line-height: 1.7;
    color: var(--color-slate);
  }

  .landing__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3) var(--space-4);
  }

  .healthcare-note__heading {
    margin: 0 0 var(--space-3);
    font-size: var(--step-2);
  }

  .healthcare-note__body {
    margin: 0;
    font-size: var(--step-0);
    line-height: 1.65;
    color: var(--color-slate);
  }
</style>
