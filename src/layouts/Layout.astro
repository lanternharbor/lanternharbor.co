---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  pageKey?: string;
  navBasePath?: string;
  /**
   * Emit a `<meta name="robots" content="noindex,nofollow">` tag. Used by
   * pages that exist as routes but aren't ready for search engines (e.g.
   * /work while project write-ups are still being assembled).
   */
  noindex?: boolean;
}

const {
  title,
  description,
  pageKey,
  navBasePath = '',
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
const siteName = 'Lantern Harbor';
const fullTitle = pageKey === 'home' ? title : `${title} — ${siteName}`;

// Schema.org structured data — tells Google/etc. this is a local professional
// service run by William Keough, based in Hingham MA, serving the South Shore.
const siteURL = Astro.site?.toString() ?? 'https://lanternharbor.co/';
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  '@id': `${siteURL}#business`,
  name: 'Lantern Harbor',
  legalName: 'Lantern Harbor LLC',
  description:
    'Practical technology help for small and mid-sized businesses on the South Shore of Massachusetts.',
  url: siteURL,
  image: new URL('/social-card.jpg', siteURL).toString(),
  logo: new URL('/logo-horizontal.png', siteURL).toString(),
  telephone: '+1-781-724-2543',
  email: 'william@lanternharbor.co',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Hingham',
    addressRegion: 'MA',
    addressCountry: 'US',
  },
  areaServed: {
    '@type': 'Place',
    name: 'South Shore of Massachusetts',
  },
  founder: {
    '@type': 'Person',
    name: 'William Keough',
    jobTitle: 'Founder & Principal',
    worksFor: { '@id': `${siteURL}#business` },
  },
  knowsAbout: [
    'Healthcare IT',
    'AI integration',
    'Workflow automation',
    'Vendor selection',
    'Website strategy',
    'Small-business technology advisory',
  ],
  priceRange: '$$',
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="theme-color" content="#0F2A3F" />
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <!-- Open Graph -->
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={new URL('/social-card.jpg', Astro.site).toString()} />
    <meta property="og:image:width" content="1536" />
    <meta property="og:image:height" content="1024" />
    <meta property="og:image:alt" content="Lantern Harbor — lantern lit against a dark harbor" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL('/social-card.jpg', Astro.site).toString()} />

    <!-- Favicon — generated from brand-source/favicon-source-1024.png. -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Fonts: Lora (headings) + Inter (body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Lora:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap"
    />

    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- LCP win: preload the hero photograph on the home page. -->
    {
      pageKey === 'home' && (
        <link rel="preload" as="image" href="/hero.jpg" fetchpriority="high" />
      )
    }

    <!-- Structured data (Schema.org) -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify(structuredData)}
    />

    <meta name="generator" content={Astro.generator} />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Header pageKey={pageKey} basePath={navBasePath} />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
