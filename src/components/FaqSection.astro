---
interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  items: FaqItem[];
}

const { items } = Astro.props;
---

<section class="faq section">
  <div class="container container--content">
    <header class="faq__intro">
      <h1 class="faq__title">Common questions</h1>
      <p class="faq__lede">
        A few things people usually want to know before reaching out.
        If your question is not here,
        <a href="/contact">send a note</a> — I am happy to answer directly.
      </p>
    </header>

    <dl class="faq__list">
      {items.map((item, i) => (
        <div class="faq__entry">
          <dt class="faq__question">
            <button
              type="button"
              class="faq__toggle"
              aria-expanded="false"
              aria-controls={`faq-answer-${i}`}
            >
              <span>{item.question}</span>
              <svg
                class="faq__chevron"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <polyline points="6 9 12 15 18 9"></polyline>
              </svg>
            </button>
          </dt>
          <dd class="faq__answer" id={`faq-answer-${i}`} hidden>
            <p>{item.answer}</p>
          </dd>
        </div>
      ))}
    </dl>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLButtonElement>('.faq__toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      const entry = btn.closest('.faq__entry');
      if (!entry) return;
      const answer = entry.querySelector<HTMLElement>('.faq__answer');

      const expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      entry.classList.toggle('is-open', !expanded);

      if (answer) {
        if (expanded) {
          // Wait for the max-height collapse transition before removing from
          // the a11y tree, so motion users still see the animation.
          answer.addEventListener(
            'transitionend',
            () => {
              if (btn.getAttribute('aria-expanded') === 'false') answer.hidden = true;
            },
            { once: true },
          );
        } else {
          answer.hidden = false;
        }
      }
    });
  });
</script>

<style>
  .faq {
    padding-top: var(--space-8);
    padding-bottom: var(--space-10);
  }

  @media (min-width: 48rem) {
    .faq {
      padding-top: var(--space-9);
    }
  }

  .faq__intro {
    margin-bottom: var(--space-8);
    max-width: var(--measure-reading);
  }

  .faq__title {
    margin: 0 0 var(--space-4);
    font-size: var(--step-5);
    line-height: 1.1;
    letter-spacing: -0.015em;
  }

  .faq__lede {
    margin: 0;
    font-size: var(--step-1);
    line-height: 1.7;
    color: var(--color-slate);
  }

  .faq__lede a {
    color: var(--color-harbor);
    font-weight: 600;
    text-decoration-color: rgba(184, 134, 75, 0.6);
    text-underline-offset: 3px;
  }

  .faq__lede a:hover,
  .faq__lede a:focus-visible {
    color: var(--color-brass);
  }

  .faq__list {
    margin: 0;
    max-width: var(--measure-reading);
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .faq__entry {
    border-top: 1px solid rgba(15, 42, 63, 0.1);
  }

  .faq__entry:last-child {
    border-bottom: 1px solid rgba(15, 42, 63, 0.1);
  }

  .faq__question {
    margin: 0;
  }

  .faq__toggle {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-5) 0;
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: var(--step-1);
    line-height: 1.3;
    color: var(--color-harbor);
    text-align: left;
    transition: color var(--transition);
  }

  .faq__toggle:hover,
  .faq__toggle:focus-visible {
    color: var(--color-brass);
  }

  .faq__toggle:focus-visible {
    outline: 2px solid var(--color-gold);
    outline-offset: 3px;
    border-radius: 2px;
  }

  .faq__chevron {
    flex-shrink: 0;
    transition: transform var(--transition);
    opacity: 0.5;
  }

  .is-open .faq__chevron {
    transform: rotate(180deg);
  }

  /* 40rem ceiling comfortably fits answers up to ~800 chars at narrow
     mobile widths. If a future answer needs more, raise this. */
  .faq__answer {
    margin: 0;
    max-height: 0;
    overflow: hidden;
    transition: max-height var(--transition-slow), padding var(--transition-slow);
  }

  .is-open .faq__answer {
    max-height: 40rem;
    padding-bottom: var(--space-5);
  }

  .faq__answer p {
    margin: 0;
    font-size: var(--step-0);
    line-height: 1.65;
    color: var(--color-slate);
  }
</style>
