---
interface Item {
  eyebrow?: string;
  title: string;
  body: string;
  ctaLabel?: string;
  ctaHref?: string;
}

interface Props {
  heading?: string;
  lede?: string;
  items: Item[];
  columns?: 2 | 3;
  sectionClass?: string;
}

const {
  heading,
  lede,
  items,
  columns = 3,
  sectionClass = 'section',
} = Astro.props;
---

<section class={sectionClass}>
  <div class="container container--content">
    {(heading || lede) && (
      <header class="card-section__header">
        {heading && <h2 class="card-section__heading">{heading}</h2>}
        {lede && <p class="card-section__lede">{lede}</p>}
      </header>
    )}

    <div class={`card-grid card-grid--${columns}`}>
      {items.map((item) => (
        <article class={`card${item.ctaLabel ? ' card--cta' : ''}`}>
          {item.eyebrow && <p class="card__eyebrow">{item.eyebrow}</p>}
          <h3 class="card__title">{item.title}</h3>
          <p class="card__body">{item.body}</p>
          {item.ctaLabel && item.ctaHref && (
            <a href={item.ctaHref} class="card__link">
              {item.ctaLabel}
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.25"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </a>
          )}
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .card__eyebrow {
    margin: 0 0 var(--space-2);
    font-size: var(--step--1);
    line-height: 1.4;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-brass);
  }
</style>
