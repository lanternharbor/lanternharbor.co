---
/**
 * LanternMark — just the lantern illustration portion of the Lantern Harbor logo.
 * Paths match `/public/lantern_harbor_logo.svg`, cropped to the lantern + clouds
 * + stars + water reflections (no wordmark or divider lines).
 *
 * Colors are themeable via CSS custom properties:
 *   --mark-cream   — flame interior
 *   --mark-gold    — lantern body, stars, reflections
 *   --mark-slate   — background clouds
 *   --mark-navy    — framing lines
 */
interface Props {
  label?: string | null;
  size?: number;
  class?: string;
  /** When true, uses a tight square viewBox focused on just the lantern body
   *  (no clouds, water, or stars). Useful for favicons and small header marks. */
  compact?: boolean;
}

const {
  label = null,
  size = 280,
  class: className = '',
  compact = false,
} = Astro.props;
const isDecorative = !label;

const viewBox = compact
  ? '682 372 236 260' // tight crop around the lantern itself
  : '380 360 840 340'; // full scene: clouds, stars, water
const aspect = compact ? 260 / 236 : 340 / 840;
const height = Math.round(size * aspect);
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox={viewBox}
  width={size}
  height={height}
  class={`lantern-mark ${className}`}
  role={isDecorative ? 'presentation' : 'img'}
  aria-hidden={isDecorative ? 'true' : undefined}
  aria-label={label ?? undefined}
  fill="none"
>
  {label && <title>{label}</title>}

  <defs>
    <linearGradient id="lmFlame" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="var(--mark-cream, #F8EED7)" />
      <stop offset="100%" stop-color="var(--mark-gold-soft, #F0D89A)" />
    </linearGradient>
  </defs>

  <!-- clouds -->
  <g fill="var(--mark-slate, #8E9AA8)" opacity="0.55">
    <path d="M472 572c18-17 38-22 66-18 20-24 60-36 96-20 14-10 35-12 53-4 14 6 26 17 35 34H472c24-2 36-5 44-12Z" />
    <path d="M890 570c22-22 53-29 86-16 17-22 57-31 88-14 18 10 29 26 36 42H890c8-7 14-9 20-12Z" />
  </g>

  <!-- stars -->
  <g fill="var(--mark-gold, #E5C067)">
    <path d="M980 432c9 22 14 27 36 36-22 9-27 14-36 36-9-22-14-27-36-36 22-9 27-14 36-36Z" />
    <path d="M1024 474c6 16 10 20 26 26-16 6-20 10-26 26-6-16-10-20-26-26 16-6 20-10 26-26Z" />
  </g>

  <!-- lantern roof -->
  <circle cx="800" cy="382" r="7.5" fill="var(--mark-gold, #E5C067)" />
  <path
    d="M800 392 770 418h60L800 392Z"
    fill="var(--mark-gold, #E5C067)"
  />
  <path
    d="M686 470 800 418l114 52H686Z"
    fill="var(--mark-gold, #E5C067)"
  />
  <path
    d="M702 470 800 425l98 45"
    stroke="var(--mark-navy, #50627A)"
    stroke-width="8"
    stroke-linecap="round"
    stroke-linejoin="round"
  />
  <path
    d="M744 451 800 425l56 26"
    stroke="var(--mark-navy, #50627A)"
    stroke-width="8"
    stroke-linecap="round"
    stroke-linejoin="round"
  />

  <!-- lantern body -->
  <path
    d="M712 470h176l-20 130H732l-20-130Z"
    fill="var(--mark-gold, #E5C067)"
  />
  <g
    stroke="var(--mark-navy, #50627A)"
    stroke-width="8"
    stroke-linecap="round"
    stroke-linejoin="round"
    fill="none"
  >
    <path d="M712 470h176" />
    <path d="M726 470 736 600" />
    <path d="M874 470 864 600" />
    <path d="M748 485 748 587" />
    <path d="M852 485 852 587" />
    <path d="M748 485 782 540" />
    <path d="M852 485 818 540" />
  </g>

  <!-- center pane + flame -->
  <rect
    x="770"
    y="495"
    width="60"
    height="92"
    rx="4"
    fill="var(--mark-cream, #F3E8C9)"
    opacity="0.35"
  />
  <path
    d="M800 494c18 23 30 42 30 62 0 21-14 36-30 36s-30-15-30-36c0-20 12-39 30-62Z"
    fill="url(#lmFlame)"
  />

  <!-- lantern base -->
  <path
    d="M736 600h128l20 18H716l20-18Z"
    fill="var(--mark-gold, #E5C067)"
  />
  <path
    d="M724 603h152"
    stroke="var(--mark-navy, #50627A)"
    stroke-width="8"
    stroke-linecap="round"
    stroke-linejoin="round"
  />
  <path
    d="M754 618h92v20h-92Z"
    fill="var(--mark-gold, #E5C067)"
  />

  <!-- water reflections -->
  <ellipse cx="710" cy="624" rx="88" ry="6" fill="var(--mark-gold, #E5C067)" opacity="0.55" />
  <ellipse cx="890" cy="624" rx="88" ry="6" fill="var(--mark-gold, #E5C067)" opacity="0.55" />
  <ellipse cx="800" cy="648" rx="108" ry="7" fill="var(--mark-gold, #E5C067)" opacity="0.9" />
  <path
    d="M800 642c18 8 34 16 49 25-18 2-31 4-44 6 18 8 33 15 49 24-27 2-42 3-54 5 15 8 28 14 41 21-24 3-54 5-81 0 12-7 24-14 38-20-15-3-32-6-56-8 18-9 35-17 52-23-18-4-31-8-45-12 16-7 32-13 51-18Z"
    fill="var(--mark-gold, #E5C067)"
  />
</svg>

<style>
  .lantern-mark {
    display: block;
    --mark-cream: #F3E8C9;
    --mark-gold: #E5C067;
    --mark-gold-soft: #F0D89A;
    --mark-slate: #8E9AA8;
    --mark-navy: #50627A;
  }
  /* Small header size: cooler in tone to blend with cream bg */
  .lantern-mark.is-compact {
    --mark-navy: rgba(15, 42, 63, 0.72);
  }
</style>
