---
import { getCollection } from 'astro:content';

/**
 * Rotating testimonials section.
 *
 * - Renders nothing if there are no featured testimonials (graceful empty).
 * - One testimonial visible at a time; gentle crossfade between.
 * - Auto-advances every 9s; pauses on hover/focus; stops after one full
 *   cycle to avoid being a rotator that never shuts up.
 * - Respects prefers-reduced-motion (stays on one, no auto-advance).
 * - Works without JS: only the first slide is visible, others hidden.
 *
 * Designed to signal authenticity through clickable company / LinkedIn
 * links, anchored engagement dates, and optional "open to reference"
 * badges. See src/content/testimonials/README.md for the principles.
 */

interface Props {
  heading?: string;
  /** Override the default copy above the rotator. */
  intro?: string;
  /** Limit how many testimonials cycle (default: all featured ones). */
  limit?: number;
}

const { heading = 'What clients say', intro, limit } = Astro.props;

const all = await getCollection('testimonials');
let items = all
  .filter((t) => t.data.featured)
  .sort((a, b) => a.data.order - b.data.order);

if (limit) items = items.slice(0, limit);
---

{
  items.length > 0 && (
    <section class="testimonials surface-warm" aria-labelledby="testimonials-heading">
      <div class="container container--content">
        <header class="testimonials__intro">
          <h2 id="testimonials-heading" class="testimonials__heading">
            {heading}
          </h2>
          {intro && <p class="testimonials__intro-text">{intro}</p>}
        </header>

        <div
          class="testimonials__rotator"
          data-rotator
          data-count={items.length}
          aria-roledescription="carousel"
          aria-label="Client testimonials"
        >
          {items.map((t, i) => {
            const { quote, name, role, company, companyURL, linkedIn, engagementDate, openToReference } = t.data;
            return (
              <article
                class="testimonial"
                data-slide={i}
                aria-roledescription="slide"
                aria-label={`${i + 1} of ${items.length}`}
                aria-hidden={i !== 0 ? 'true' : 'false'}
              >
                <blockquote class="testimonial__quote">
                  <svg
                    class="testimonial__mark"
                    aria-hidden="true"
                    viewBox="0 0 40 32"
                    width="40"
                    height="32"
                  >
                    <path
                      d="M12 0C5.373 0 0 5.373 0 12v20h12V16H6c0-3.314 2.686-6 6-6V0zm20 0c-6.627 0-12 5.373-12 12v20h12V16h-6c0-3.314 2.686-6 6-6V0z"
                      fill="currentColor"
                    />
                  </svg>
                  <p>{quote}</p>
                </blockquote>

                <footer class="testimonial__cite">
                  <div class="testimonial__person">
                    <span class="testimonial__name">{name}</span>
                    <span class="testimonial__sep" aria-hidden="true">·</span>
                    <span class="testimonial__role">{role}</span>
                  </div>
                  <div class="testimonial__links">
                    {companyURL ? (
                      <a
                        href={companyURL}
                        class="testimonial__company"
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        {company}
                      </a>
                    ) : (
                      <span class="testimonial__company">{company}</span>
                    )}
                    {linkedIn && (
                      <a
                        href={linkedIn}
                        class="testimonial__linkedin"
                        target="_blank"
                        rel="noopener noreferrer"
                        aria-label={`${name} on LinkedIn`}
                      >
                        LinkedIn
                      </a>
                    )}
                    {engagementDate && (
                      <span class="testimonial__date">{engagementDate}</span>
                    )}
                  </div>
                  {openToReference && (
                    <div class="testimonial__reference">
                      <span aria-hidden="true">✓</span>
                      Open to a reference call
                    </div>
                  )}
                </footer>
              </article>
            );
          })}

          {items.length > 1 && (
            <nav class="testimonials__nav" aria-label="Testimonial controls">
              <button
                type="button"
                class="testimonials__arrow"
                data-prev
                aria-label="Previous testimonial"
              >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="15 18 9 12 15 6" />
                </svg>
              </button>
              <div class="testimonials__dots" role="tablist">
                {items.map((_, i) => (
                  <button
                    type="button"
                    class="testimonials__dot"
                    data-dot={i}
                    aria-label={`Go to testimonial ${i + 1}`}
                    aria-selected={i === 0 ? 'true' : 'false'}
                    role="tab"
                  />
                ))}
              </div>
              <button
                type="button"
                class="testimonials__arrow"
                data-next
                aria-label="Next testimonial"
              >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="9 18 15 12 9 6" />
                </svg>
              </button>
            </nav>
          )}
        </div>
      </div>
    </section>
  )
}

<script>
  const rotator = document.querySelector<HTMLElement>('[data-rotator]');
  if (rotator) {
    const slides = Array.from(rotator.querySelectorAll<HTMLElement>('[data-slide]'));
    const dots = Array.from(rotator.querySelectorAll<HTMLElement>('[data-dot]'));
    const prev = rotator.querySelector<HTMLButtonElement>('[data-prev]');
    const next = rotator.querySelector<HTMLButtonElement>('[data-next]');
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let index = 0;
    let timer: number | undefined;
    let cycled = false;

    const show = (i: number) => {
      slides.forEach((el, j) => {
        const active = j === i;
        el.setAttribute('aria-hidden', String(!active));
        el.classList.toggle('is-active', active);
      });
      dots.forEach((el, j) => el.setAttribute('aria-selected', String(j === i)));
      index = i;
    };

    const advance = (delta: number) => {
      const n = slides.length;
      const next = (index + delta + n) % n;
      if (next === 0) cycled = true;
      show(next);
    };

    const startAuto = () => {
      if (reducedMotion || slides.length < 2 || cycled) return;
      stopAuto();
      timer = window.setInterval(() => {
        advance(1);
        if (cycled) stopAuto();
      }, 9000);
    };

    const stopAuto = () => {
      if (timer !== undefined) {
        clearInterval(timer);
        timer = undefined;
      }
    };

    prev?.addEventListener('click', () => {
      advance(-1);
      stopAuto();
    });
    next?.addEventListener('click', () => {
      advance(1);
      stopAuto();
    });
    dots.forEach((dot) =>
      dot.addEventListener('click', () => {
        const i = Number(dot.dataset.dot ?? 0);
        show(i);
        stopAuto();
      }),
    );

    rotator.addEventListener('mouseenter', stopAuto);
    rotator.addEventListener('focusin', stopAuto);
    rotator.addEventListener('mouseleave', startAuto);

    // Kick off initial state.
    show(0);
    startAuto();
  }
</script>

<style>
  .testimonials {
    padding-block: var(--space-9);
    background-color: rgba(229, 192, 103, 0.06);
    border-top: 1px solid rgba(229, 192, 103, 0.25);
    border-bottom: 1px solid rgba(229, 192, 103, 0.25);
  }

  .testimonials__intro {
    max-width: 32rem;
    margin-bottom: var(--space-7);
  }

  .testimonials__heading {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: var(--step-3);
    line-height: 1.2;
    color: var(--color-harbor);
    margin: 0 0 var(--space-3);
  }

  .testimonials__intro-text {
    margin: 0;
    font-size: var(--step-0);
    color: var(--color-driftwood);
    line-height: 1.6;
  }

  .testimonials__rotator {
    position: relative;
  }

  /* Slides — stacked, fade-swapped */
  .testimonial {
    position: absolute;
    inset: 0;
    opacity: 0;
    pointer-events: none;
    transition: opacity 400ms ease;
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }
  .testimonial.is-active {
    position: relative;
    opacity: 1;
    pointer-events: auto;
  }
  .testimonial:first-child {
    position: relative;
  }

  @media (prefers-reduced-motion: reduce) {
    .testimonial {
      transition: none;
    }
  }

  .testimonial__quote {
    margin: 0;
    position: relative;
    padding-left: var(--space-7);
  }

  .testimonial__mark {
    position: absolute;
    left: 0;
    top: 0.25rem;
    color: var(--color-brass);
    opacity: 0.5;
  }

  .testimonial__quote p {
    font-family: var(--font-heading);
    font-weight: 500;
    font-size: clamp(1.25rem, 1rem + 0.6vw, 1.65rem);
    line-height: 1.45;
    color: var(--color-harbor);
    margin: 0;
    font-style: italic;
    max-width: 44em;
  }

  .testimonial__cite {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding-left: var(--space-7);
  }

  .testimonial__person {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.4rem;
    font-size: var(--step-0);
  }

  .testimonial__name {
    font-weight: 700;
    color: var(--color-harbor);
  }

  .testimonial__sep {
    color: var(--color-driftwood);
  }

  .testimonial__role {
    color: var(--color-slate);
  }

  .testimonial__links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    align-items: baseline;
    font-size: var(--step--1);
    color: var(--color-driftwood);
  }

  .testimonial__company {
    color: var(--color-harbor);
    font-weight: 500;
    text-decoration-color: rgba(184, 134, 75, 0.45);
    text-underline-offset: 3px;
  }
  a.testimonial__company:hover,
  a.testimonial__company:focus-visible {
    color: var(--color-brass);
  }

  .testimonial__linkedin {
    color: var(--color-driftwood);
    text-decoration-color: rgba(107, 93, 79, 0.35);
    text-underline-offset: 3px;
  }
  .testimonial__linkedin:hover,
  .testimonial__linkedin:focus-visible {
    color: var(--color-harbor);
  }

  .testimonial__date {
    color: var(--color-driftwood);
    font-style: italic;
  }

  .testimonial__reference {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: var(--step--1);
    color: var(--color-harbor);
    padding: 0.2rem 0.6rem;
    background-color: rgba(229, 192, 103, 0.22);
    border: 1px solid rgba(229, 192, 103, 0.45);
    border-radius: 999px;
    margin-top: var(--space-2);
    align-self: flex-start;
  }
  .testimonial__reference span {
    color: var(--color-brass);
    font-weight: 700;
  }

  /* Navigation */
  .testimonials__nav {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-top: var(--space-6);
  }

  .testimonials__arrow {
    width: 36px;
    height: 36px;
    border-radius: 999px;
    border: 1px solid rgba(15, 42, 63, 0.15);
    background: transparent;
    color: var(--color-harbor);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition:
      background-color var(--transition),
      border-color var(--transition);
  }
  .testimonials__arrow:hover,
  .testimonials__arrow:focus-visible {
    background-color: rgba(229, 192, 103, 0.16);
    border-color: rgba(229, 192, 103, 0.55);
    outline: none;
  }

  .testimonials__dots {
    display: flex;
    gap: 0.5rem;
  }

  .testimonials__dot {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background-color: rgba(15, 42, 63, 0.2);
    border: none;
    padding: 0;
    cursor: pointer;
    transition:
      background-color var(--transition),
      transform 120ms ease;
  }
  .testimonials__dot:hover {
    background-color: rgba(15, 42, 63, 0.4);
  }
  .testimonials__dot[aria-selected='true'] {
    background-color: var(--color-brass);
    transform: scale(1.25);
  }
  .testimonials__dot:focus-visible {
    outline: 2px solid var(--color-gold);
    outline-offset: 2px;
  }
</style>
