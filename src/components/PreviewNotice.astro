---
interface Props {
  title: string;
  body: string;
  primaryHref: string;
  primaryLabel: string;
}

const { title, body, primaryHref, primaryLabel } = Astro.props;
---

<section class="preview-notice">
  <div class="container container--content preview-notice__inner">
    <div>
      <p class="preview-notice__eyebrow">Preview route</p>
      <h2 class="preview-notice__title">{title}</h2>
      <p class="preview-notice__body">{body}</p>
    </div>
    <a href={primaryHref} class="preview-notice__link">{primaryLabel}</a>
  </div>
</section>

<style>
  .preview-notice {
    padding-block: var(--space-5);
    background-color: rgba(15, 42, 63, 0.04);
    border-bottom: 1px solid rgba(15, 42, 63, 0.08);
  }

  .preview-notice__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  @media (min-width: 48rem) {
    .preview-notice__inner {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-6);
    }
  }

  .preview-notice__eyebrow {
    margin: 0 0 var(--space-2);
    font-size: var(--step--1);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-brass);
  }

  .preview-notice__title {
    margin: 0 0 var(--space-2);
    font-size: var(--step-2);
  }

  .preview-notice__body {
    margin: 0;
    max-width: 44rem;
    font-size: var(--step-0);
    line-height: 1.6;
    color: var(--color-slate);
  }

  .preview-notice__link {
    white-space: nowrap;
    font-weight: 600;
    text-decoration-color: rgba(184, 134, 75, 0.5);
  }
</style>
