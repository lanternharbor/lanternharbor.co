---
interface Step {
  title: string;
  body: string;
}

interface Props {
  heading: string;
  lede?: string;
  items: Step[];
}

const { heading, lede, items } = Astro.props;
---

<section class="process section section--tight">
  <div class="container container--content">
    <header class="process__intro">
      <h2 class="process__heading">{heading}</h2>
      {lede && <p class="process__lede">{lede}</p>}
    </header>

    <ol class="process__grid">
      {items.map((step, index) => (
        <li class="process__item">
          <span class="process__number" aria-hidden="true">{index + 1}</span>
          <h3 class="process__title">{step.title}</h3>
          <p class="process__body">{step.body}</p>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .process__intro {
    max-width: var(--measure-intro);
    margin-bottom: var(--space-7);
  }

  .process__heading {
    margin: 0 0 var(--space-3);
  }

  .process__lede {
    margin: 0;
    font-size: var(--step-1);
    line-height: 1.6;
    color: var(--color-slate);
  }

  .process__grid {
    list-style: none;
    counter-reset: process;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }

  @media (min-width: 52rem) {
    .process__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .process__item {
    position: relative;
    padding: var(--space-6);
    background-color: rgba(245, 239, 228, 0.75);
    border: 1px solid rgba(15, 42, 63, 0.1);
    border-radius: var(--radius);
  }

  .process__number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.2rem;
    height: 2.2rem;
    margin-bottom: var(--space-4);
    border-radius: 999px;
    background-color: rgba(229, 192, 103, 0.2);
    border: 1px solid rgba(184, 134, 75, 0.35);
    color: var(--color-harbor);
    font-family: var(--font-heading);
    font-weight: 700;
  }

  .process__title {
    margin: 0 0 var(--space-3);
    font-size: var(--step-2);
  }

  .process__body {
    margin: 0;
    font-size: var(--step-0);
    line-height: 1.65;
    color: var(--color-slate);
  }
</style>
