{
  "$comment": "Lantern Harbor brand tokens. Mirrors src/styles/global.css. lanternGlow is illustration-only.",
  "color": {
    "harbor":     { "value": "#0F2A3F", "role": "deep navy — primary dark surfaces" },
    "lantern":    { "value": "#F5EFE4", "role": "warm cream — primary light / page bg" },
    "gold":       { "value": "#E5C067", "role": "luminous gold — CTAs, accents" },
    "goldSoft":   { "value": "#F3E8C9", "role": "cream highlight from the wordmark" },
    "brass":      { "value": "#B8864B", "role": "deeper muted gold — decoration, hover" },
    "brassText":  { "value": "#836034", "role": "body text on cream, >=4.5:1" },
    "ember":      { "value": "#7A3E2C", "role": "deep warm — hover states" },
    "driftwood":  { "value": "#6B5D4F", "role": "body text on cream" },
    "fog":        { "value": "#D9D2C3", "role": "dividers, subtle backgrounds" },
    "slate":      { "value": "#2A3842", "role": "secondary dark" },
    "mist":       { "value": "#8E9AA8", "role": "cool gray-blue — cloud tones" },
    "navyline":   { "value": "#50627A", "role": "lantern frame lines" },
    "lanternGlow":{ "value": "#E9A23C", "role": "ILLUSTRATION ONLY — warm flame/glow in artwork" }
  },
  "usageRatio": { "cream": 60, "navy": 30, "gold": 10, "note": "rough balance: cream ground, navy structure, gold accent" },
  "textPairings": {
    "onCream":  { "body": "#6B5D4F", "bodyStrong": "#836034", "heading": "#0F2A3F" },
    "onNavy":   { "body": "rgba(245,239,228,0.88)", "heading": "#F5EFE4", "accent": "#E5C067" }
  },
  "font": {
    "heading": "Lora, Georgia, 'Times New Roman', serif",
    "body": "Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif"
  },
  "typeScale": {
    "step-1": "clamp(0.875rem, 0.83rem + 0.22vw, 1rem)",
    "step0":  "clamp(1rem, 0.95rem + 0.25vw, 1.125rem)",
    "step1":  "clamp(1.125rem, 1.05rem + 0.4vw, 1.313rem)",
    "step2":  "clamp(1.375rem, 1.25rem + 0.6vw, 1.625rem)",
    "step3":  "clamp(1.625rem, 1.45rem + 0.9vw, 2rem)",
    "step4":  "clamp(2rem, 1.7rem + 1.5vw, 2.75rem)",
    "step5":  "clamp(2.5rem, 2rem + 2.75vw, 4rem)",
    "step6":  "clamp(3rem, 2.2rem + 4vw, 4.75rem)"
  }
}
